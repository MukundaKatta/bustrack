{
  "name": "bustrack",
  "version": "0.0.0",
  "private": true,
  "description": "BusTrack monorepo (Team Zion): apps/web (Next.js), apps/mobile (Expo), packages/shared",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prisma:generate": "prisma generate --schema packages/shared/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema packages/shared/prisma/schema.prisma --name align_prd_schema",
    "prisma:seed": "prisma db seed --schema packages/shared/prisma/schema.prisma",
    "db:seed": "pnpm prisma:seed",
    "db:ping": "tsx test-db.ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "prettier": "^3.3.3",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "pg": "^8.20.0"
  },
  "prisma": {
    "seed": "node packages/shared/prisma/seed.js"
  }
}
